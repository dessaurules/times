# ── PocketBase ────────────────────────────────────────────
PB_URL=http://127.0.0.1:8092
PB_ADMIN_EMAIL=admin@example.com
PB_ADMIN_PASSWORD=ÄNDERN!YourSecurePasswordHere123!

# ── Web Push Notifications (VAPID) ────────────────────────────
# Generiert via: npx web-push generate-vapid-keys
# Muss gleich sein wie in mitarbeiter-app/.env.local
VAPID_PUBLIC=BLdY0lmhgwq...
VAPID_PRIVATE=o_4B7jcDU-OQ...
VAPID_SUBJECT=mailto:admin@example.com

# ── Push-Service Server ────────────────────────────────────────
PORT=3457
